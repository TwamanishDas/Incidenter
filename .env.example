# Azure Authentication
# Method 1: Managed Identity (recommended for production - running in Azure)
# - No configuration needed if running in Azure App Service, Container Apps, or AKS with system-assigned managed identity

# Method 2: Service Principal (for development/testing)
# Create a service principal: az ad sp create-for-rbac --name myapp --role Reader
# Then set these environment variables:
AZURE_TENANT_ID=your-tenant-id
AZURE_SUBSCRIPTION_ID=your-subscription-id
AZURE_CLIENT_ID=your-service-principal-client-id
AZURE_CLIENT_SECRET=your-service-principal-client-secret

# Method 3: Azure CLI (local development)
# Run: az login
# Then the app will automatically use your CLI credentials

# Optional: disable managed identity attempt in local/non-Azure environments
# AZURE_DISABLE_MANAGED_IDENTITY=true

# Ingestion mode:
# - live: query Azure APIs directly
# - sample_blob: replay normalized JSONL events from blob storage
INGESTION_MODE=live

# ============================================================================
# DATA SOURCE CONFIGURATION
# ============================================================================

# Log Analytics Workspace
# Find workspace ID in Azure Portal > Log Analytics > Your Workspace > Properties > Workspace ID
LOG_ANALYTICS_WORKSPACE_ID=your-workspace-id

# Application Insights
# Preferred: full Azure resource ID (used by query_resource API)
# Format: /subscriptions/{sub-id}/resourceGroups/{rg}/providers/microsoft.insights/components/{appinsights-name}
APP_INSIGHTS_RESOURCE_ID=/subscriptions/your-sub-id/resourceGroups/your-rg/providers/microsoft.insights/components/your-appinsights
# Deprecated only for migration reference: APP_INSIGHTS_APP_ID is not used by collectors
APP_INSIGHTS_APP_ID=your-app-insights-app-id

# Network Watcher
# Typically deployed automatically by Azure in NetworkWatcherRG resource group
NETWORK_WATCHER_RESOURCE_GROUP=NetworkWatcherRG
NETWORK_WATCHER_NAME=NetworkWatcher_eastus

# Azure Monitor - Resource IDs to monitor
# Format: /subscriptions/{sub-id}/resourceGroups/{rg}/providers/{resource-type}/{resource-name}
# Separate multiple with comma
MONITOR_RESOURCE_IDS=/subscriptions/your-sub-id/resourceGroups/your-rg/providers/Microsoft.Sql/servers/your-sqlserver/databases/your-db,/subscriptions/your-sub-id/resourceGroups/your-rg/providers/Microsoft.Compute/virtualMachines/your-vm
# Optional JSON map for region enrichment when region is not present in metrics payload
# Example: {"<resource-id>":"eastus","<resource-id-2>":"westeurope"}
RESOURCE_REGION_OVERRIDES_JSON={}

# ============================================================================
# SAMPLE BLOB REPLAY (used when INGESTION_MODE=sample_blob)
# ============================================================================

# Blob service/container SAS URL with at least read + list permissions.
SAMPLE_BLOB_SAS_URL=
# Container name where sample replay files are stored
SAMPLE_BLOB_CONTAINER=rca-sample-ingestion
# Prefix root under container (e.g. v1/log_analytics/...)
SAMPLE_BLOB_PREFIX=v1
# true: replace event timestamps with current UTC during replay
SAMPLE_REPLAY_REBASE_TIMESTAMPS=true

# ============================================================================
# SCHEDULER CONFIGURATION
# ============================================================================

# Collection interval in seconds (how often to poll Azure telemetry)
COLLECTION_INTERVAL=30

# Lookback window in minutes (how far back to query for telemetry)
LOOKBACK_MINUTES=5

# Overlap to avoid gaps between scheduler cycles (seconds)
LOOKBACK_OVERLAP_SECONDS=30

# Delay query end time to avoid indexing lag (seconds)
INGESTION_DELAY_SECONDS=60

# Deduplication TTL to suppress repeat incidents from overlapping windows (minutes)
DEDUP_WINDOW_MINUTES=10
